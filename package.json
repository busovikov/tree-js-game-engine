{
  "name": "haku",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm -r run build",
    "dev": "pnpm -r --parallel run dev",
    "test": "vitest run",
    "lint": "eslint .",
    "typecheck": "pnpm -r run typecheck",
    "depcruise": "depcruise packages apps --config .dependency-cruiser.cjs --ignore-known",
    "depcruise:baseline": "depcruise packages apps --config .dependency-cruiser.cjs --output-type baseline > .dependency-cruiser-known-violations.json"
  },
  "devDependencies": {
    "@eslint/js": "^9.16.0",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "dependency-cruiser": "^16.0.0",
    "eslint": "^9.16.0",
    "eslint-plugin-import": "^2.31.0",
    "happy-dom": "^15.11.7",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0",
    "vitest": "^2.1.8"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  }
}
