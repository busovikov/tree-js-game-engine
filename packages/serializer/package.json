{
  "name": "@haku/serializer",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "import": "./dist/node.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@haku/core": "file:../core",
    "@haku/schema": "file:../schema"
  },
  "devDependencies": {
    "@types/node": "^22.19.21",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
